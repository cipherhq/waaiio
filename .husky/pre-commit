#!/usr/bin/env bash

# Pre-commit secret scanner
# Override with: git commit --no-verify

set -euo pipefail

ERRORS=0

# ============================================================
# 1. Block .env files (except .env.example)
# ============================================================
ENV_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.env($|\..*)' | grep -v '\.env\.example$' || true)

if [ -n "$ENV_FILES" ]; then
  echo ""
  echo "ERROR: Attempted to commit .env file(s):"
  echo "$ENV_FILES" | while read -r f; do
    echo "  - $f"
  done
  echo ""
  echo "Remove them with: git reset HEAD <file>"
  ERRORS=1
fi

# ============================================================
# 2. Scan staged content for secrets
# ============================================================
SECRET_PATTERNS=(
  'sk_live_[a-zA-Z0-9]+'
  'sk_test_[a-zA-Z0-9]+'
  'eyJhbGci[a-zA-Z0-9_=-]+'
  '-----BEGIN[[:space:]]+(RSA|EC|DSA|OPENSSH|PGP)?[[:space:]]*PRIVATE KEY-----'
  'password[[:space:]]*=[[:space:]]*["\x27][^"\x27]+'
  'passwd[[:space:]]*=[[:space:]]*["\x27][^"\x27]+'
  'pwd[[:space:]]*=[[:space:]]*["\x27][^"\x27]+'
  'secret_key[[:space:]]*=[[:space:]]*["\x27][^"\x27]+'
  'api_key[[:space:]]*=[[:space:]]*["\x27][^"\x27]+'
  'auth_token[[:space:]]*=[[:space:]]*["\x27][^"\x27]+'
  'Bearer[[:space:]]+[a-zA-Z0-9_\.-]{20,}'
  'SUPABASE_SERVICE_ROLE_KEY=[a-zA-Z0-9]+'
  're_[a-zA-Z0-9]{20,}'
  'AC[0-9a-f]{32}'
  'SG\.[a-zA-Z0-9_\.-]+'
  'AIzaSy[a-zA-Z0-9_-]{33}'
  'ghp_[a-zA-Z0-9]{36,}'
  'gho_[a-zA-Z0-9]{36,}'
  'github_pat_[a-zA-Z0-9_]{22,}'
  'sbp_[a-zA-Z0-9]{40,}'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '\.husky/' || true)

if [ -n "$STAGED_FILES" ]; then
  # Build a combined pattern for a single grep pass
  COMBINED=""
  for pattern in "${SECRET_PATTERNS[@]}"; do
    if [ -z "$COMBINED" ]; then
      COMBINED="$pattern"
    else
      COMBINED="$COMBINED|$pattern"
    fi
  done

  # Scan staged diff content (only added/modified lines)
  MATCHES=$(git diff --cached -U0 --diff-filter=ACM | grep -nE "^\+" | grep -v "^+++\|^+#\|^+//.*TODO\|^+//.*FIXME" | grep -iE "$COMBINED" || true)

  if [ -n "$MATCHES" ]; then
    echo ""
    echo "ERROR: Potential secrets detected in staged changes:"
    echo ""
    echo "$MATCHES" | head -20 | while IFS= read -r line; do
      echo "  $line"
    done
    MATCH_COUNT=$(echo "$MATCHES" | wc -l | tr -d ' ')
    if [ "$MATCH_COUNT" -gt 20 ]; then
      echo "  ... and $((MATCH_COUNT - 20)) more matches"
    fi
    echo ""
    echo "If these are false positives, commit with: git commit --no-verify"
    ERRORS=1
  fi
fi

# ============================================================
# 3. Block large files (> 5MB)
# ============================================================
LARGE_FILES=""
while IFS= read -r file; do
  [ -z "$file" ] && continue
  [ ! -f "$file" ] && continue
  FILE_SIZE=$(wc -c < "$file" | tr -d ' ')
  if [ "$FILE_SIZE" -gt 5242880 ]; then
    LARGE_FILES="$LARGE_FILES\n  - $file ($(( FILE_SIZE / 1048576 ))MB)"
  fi
done <<< "$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)"

if [ -n "$LARGE_FILES" ]; then
  echo ""
  echo "ERROR: Files exceeding 5MB limit:"
  echo -e "$LARGE_FILES"
  echo ""
  ERRORS=1
fi

# ============================================================
# Exit
# ============================================================
if [ "$ERRORS" -ne 0 ]; then
  echo "Commit blocked. Fix the issues above or use --no-verify to override."
  exit 1
fi
