{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "waaiio.com" }],
      "destination": "https://www.waaiio.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/customer-intelligence",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/auto-payout",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/recurring-invoices",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/cron/subscription-expiry",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/trial-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/balance-reminder",
      "schedule": "15 9 * * *"
    },
    {
      "path": "/api/cron/business-health",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/low-stock-alerts",
      "schedule": "20 10 * * *"
    },
    {
      "path": "/api/cron/payout-nudge",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/quote-expiry",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/scheduled-broadcasts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 1 * * 0"
    },
    {
      "path": "/api/cron/payment-reconciliation",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/catalog-sync",
      "schedule": "30 */6 * * *"
    }
  ]
}
