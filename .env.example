# ============================================================
# Waaiio Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Lines marked [REQUIRED] must be set for the app to function.
# Lines marked [OPTIONAL] enable additional features.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.waaiio.com            # [REQUIRED] Must use www

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here            # [REQUIRED]
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here         # [REQUIRED] Server-only, never expose to client

# ── Authentication / Security ────────────────────────────────
INTERNAL_API_TOKEN=your_internal_api_token_here        # [REQUIRED] Used by bot for internal API calls (receipts, etc.)
TOKEN_ENCRYPTION_KEY=your_encryption_key_here          # [REQUIRED] HMAC signing for OTP tokens
CRON_SECRET=your_cron_secret_here                      # [REQUIRED] Vercel cron job authentication
TURNSTILE_SECRET_KEY=your_turnstile_secret_here        # [OPTIONAL] Cloudflare Turnstile bot protection

# ── Admin Panel ──────────────────────────────────────────────
ADMIN_ORIGIN=https://admin.waaiio.com                  # [OPTIONAL] CORS origin for admin panel

# ── WhatsApp / Meta Cloud API ────────────────────────────────
META_CLOUD_ACCESS_TOKEN=your_meta_access_token_here    # [REQUIRED] Meta Cloud API permanent token
META_CLOUD_WABA_ID=your_waba_id_here                   # [REQUIRED] WhatsApp Business Account ID
META_CLOUD_PHONE_NUMBER_ID=your_phone_number_id_here   # [REQUIRED] Meta phone number ID
META_APP_SECRET=your_meta_app_secret_here              # [REQUIRED] Webhook signature verification
META_APP_ID=your_meta_app_id_here                      # [REQUIRED] Meta App ID (server-side)
NEXT_PUBLIC_META_APP_ID=your_meta_app_id_here          # [REQUIRED] Meta App ID (client-side, embedded signup)
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=your_config_id_here  # [OPTIONAL] Embedded signup config
META_WEBHOOK_VERIFY_TOKEN=your_verify_token_here       # [REQUIRED] Webhook verification challenge
META_GRAPH_API_VERSION=v21.0                           # [OPTIONAL] Meta Graph API version

# ── WhatsApp / Gupshup (shared numbers) ─────────────────────
GUPSHUP_API_KEY=your_gupshup_api_key_here              # [REQUIRED] Gupshup API key
GUPSHUP_APP_NAME=Waaiio                                # [REQUIRED] Gupshup app name
GUPSHUP_PHONE_NUMBER=your_gupshup_phone_here           # [REQUIRED] Gupshup sender phone
GUPSHUP_WEBHOOK_SECRET=your_gupshup_webhook_secret     # [REQUIRED] Gupshup webhook signature
NEXT_PUBLIC_GUPSHUP_WHATSAPP_NUMBER=your_number_here   # [OPTIONAL] Displayed on frontend

# ── WhatsApp country numbers (displayed on frontend) ────────
NEXT_PUBLIC_WHATSAPP_NUMBER_US=your_us_number_here     # [OPTIONAL]
NEXT_PUBLIC_WHATSAPP_NUMBER_CA=your_ca_number_here     # [OPTIONAL]
NEXT_PUBLIC_WHATSAPP_NUMBER_NG=your_ng_number_here     # [OPTIONAL]
NEXT_PUBLIC_WHATSAPP_NUMBER_GH=your_gh_number_here     # [OPTIONAL]
NEXT_PUBLIC_WHATSAPP_NUMBER_GB=your_gb_number_here     # [OPTIONAL]

# ── WhatsApp templates ───────────────────────────────────────
WHATSAPP_CONTRACT_TEMPLATE=your_template_name_here     # [OPTIONAL] Contract signing template name

# ── Legacy WhatsApp (if used) ────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token_here                # [OPTIONAL] Legacy token
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here            # [OPTIONAL] Legacy phone number ID

# ── Payments: Paystack (NG/GH) ──────────────────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_here          # [REQUIRED] Paystack secret key
PAYSTACK_GROWTH_PLAN_CODE=your_plan_code_here          # [REQUIRED] Subscription plan codes
PAYSTACK_BUSINESS_PLAN_CODE=your_plan_code_here        # [REQUIRED]

# ── Payments: Stripe (US/GB/CA) ──────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_here              # [REQUIRED] Stripe secret key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here  # [REQUIRED] Stripe webhook signing secret
STRIPE_PAYOUT_WEBHOOK_SECRET=your_payout_webhook_here  # [OPTIONAL] Separate webhook for payouts

# ── Payments: Flutterwave ────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_here    # [OPTIONAL]
FLUTTERWAVE_WEBHOOK_HASH=your_webhook_hash_here        # [OPTIONAL] Webhook verification hash
FLW_SECRET_HASH=your_flw_hash_here                     # [OPTIONAL] Alternative webhook hash key

# ── Payments: Square ─────────────────────────────────────────
SQUARE_ACCESS_TOKEN=your_square_token_here             # [OPTIONAL]
SQUARE_LOCATION_ID=your_location_id_here               # [OPTIONAL]
SQUARE_ENVIRONMENT=sandbox                             # [OPTIONAL] sandbox or production
SQUARE_WEBHOOK_SIGNATURE_KEY=your_signature_key_here   # [OPTIONAL]
SQUARE_WEBHOOK_NOTIFICATION_URL=your_webhook_url_here  # [OPTIONAL]
SQUARE_APPLICATION_ID=your_app_id_here                 # [OPTIONAL] OAuth app ID
SQUARE_APPLICATION_SECRET=your_app_secret_here         # [OPTIONAL] OAuth app secret
SQUARE_OAUTH_APP_ID=your_oauth_app_id_here             # [OPTIONAL]
SQUARE_OAUTH_APP_SECRET=your_oauth_secret_here         # [OPTIONAL]

# ── Payments: PayPal ─────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id_here            # [OPTIONAL]
PAYPAL_CLIENT_SECRET=your_paypal_secret_here           # [OPTIONAL]
PAYPAL_ENVIRONMENT=sandbox                             # [OPTIONAL] sandbox or production
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here          # [OPTIONAL]

# ── AI / LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here              # [REQUIRED] Claude API for intent detection + AI setup
OPENAI_API_KEY=your_openai_key_here                    # [OPTIONAL] Whisper voice transcription

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=your_resend_key_here                    # [REQUIRED]
EMAIL_FROM=noreply@waaiio.com                          # [OPTIONAL] Sender email address
FALLBACK_EMAIL_DOMAIN=waaiio.com                       # [OPTIONAL] Fallback domain for email

# ── Monitoring: Sentry ───────────────────────────────────────
SENTRY_DSN=your_sentry_dsn_here                        # [REQUIRED] Server-side DSN
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here            # [REQUIRED] Client-side DSN
SENTRY_ORG=your_sentry_org_here                        # [REQUIRED] For source maps upload
SENTRY_PROJECT=your_sentry_project_here                # [REQUIRED]

# ── Analytics: PostHog ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here          # [OPTIONAL]
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com      # [OPTIONAL]

# ── Redis (Upstash) ─────────────────────────────────────────
UPSTASH_REDIS_REST_URL=your_redis_url_here             # [OPTIONAL] Rate limiting — falls back to in-memory
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here         # [OPTIONAL]

# ── Google APIs ──────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_places_key_here # [OPTIONAL] Google Places autocomplete
GOOGLE_SITE_VERIFICATION=your_verification_code_here   # [OPTIONAL] Google Search Console
GOOGLE_CALENDAR_CLIENT_ID=your_calendar_id_here        # [OPTIONAL] Google Calendar integration
GOOGLE_CALENDAR_CLIENT_SECRET=your_calendar_secret     # [OPTIONAL]
